
<div style="padding:16px;background:#fee2e2;border:1px solid #fca5a5;border-radius:8px;text-align:center;font-family:sans-serif">
  <p style="margin:0 0 4px;font-size:14px;font-weight:600">🔥 Offer ends in <span id="test-timer-{{ section.id }}">--:--:--</span></p>
  <p style="margin:0;font-size:13px;opacity:0.7" id="test-stock-{{ section.id }}"></p>
</div>

<script>
  (function() {
    var id = '{{ section.id }}';
    var min = {{ section.settings.min_m | default: 5 }};
    var max = {{ section.settings.max_m | default: 60 }};
    var stockMin = {{ section.settings.stock_min | default: 3 }};
    var stockMax = {{ section.settings.stock_max | default: 28 }};

    var stockEl = document.getElementById('test-stock-' + id);
    if (stockEl) {
      var s = Math.floor(Math.random() * (stockMax - stockMin + 1)) + stockMin;
      stockEl.textContent = s + ' left in stock';
    }

    var timerEl = document.getElementById('test-timer-' + id);
    if (!timerEl) return;

    var key = 'test-urgency-' + id;
    var end = parseInt(localStorage.getItem(key), 10);
    if (!end || end <= Date.now()) {
      end = Date.now() + (Math.random() * (max - min) + min) * 60000;
      localStorage.setItem(key, end);
    }

    function tick() {
      var diff = end - Date.now();
      if (diff <= 0) { timerEl.textContent = 'Offer expired'; return; }
      var h = Math.floor(diff / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      var s = Math.floor((diff % 60000) / 1000);
      timerEl.textContent = String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
    }
    tick();
    setInterval(tick, 1000);
  })();
</script>

{% schema %}
{
  "name": "Test Urgency",
  "settings": [
    { "type": "range", "id": "min_m", "label": "Min minutes", "min": 1, "max": 1440, "step": 1, "default": 5 },
    { "type": "range", "id": "max_m", "label": "Max minutes", "min": 1, "max": 1440, "step": 1, "default": 60 },
    { "type": "range", "id": "stock_min", "label": "Stock min", "min": 1, "max": 100, "step": 1, "default": 3 },
    { "type": "range", "id": "stock_max", "label": "Stock max", "min": 1, "max": 200, "step": 1, "default": 28 }
  ],
  "presets": [{ "name": "Test Urgency", "category": "Custom" }]
}
{% endschema %}

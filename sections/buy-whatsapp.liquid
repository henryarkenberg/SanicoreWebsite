
{% liquid
  assign wa_number = settings.whatsapp_number | default: '15551234567' | replace: '+', '' | replace: ' ', ''
  assign section_heading = section.settings.heading | default: 'Order via WhatsApp'
%}

<div class="section-background"></div>
<div class="section section--{{ section.settings.section_width }} spacing-style" style="{% render 'spacing-padding', settings: section.settings %}">
  <div class="buy-whatsapp-wrapper">
    {% if section_heading != blank %}
      <h3 class="buy-whatsapp-heading">{{ section_heading }}</h3>
    {% endif %}
    <p class="buy-whatsapp-desc">Pre-fill your selections and start a chat with us to place your order.</p>
    <button type="button" class="buy-whatsapp-btn" data-wa-number="{{ wa_number }}">
      <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      {{ section.settings.button_text | default: 'Order on WhatsApp' }}
    </button>
  </div>
</div>

<style>
  .buy-whatsapp-wrapper {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }

  .buy-whatsapp-heading {
    margin: 0;
    font-size: 16px;
    line-height: 1.3;
  }

  .buy-whatsapp-desc {
    margin: 0;
    font-size: 13px;
    opacity: 0.65;
  }

  .buy-whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #25D366;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 10px 20px;
    font: inherit;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, transform 0.15s;
    -webkit-tap-highlight-color: transparent;
  }

  .buy-whatsapp-btn:hover {
    background: #1da951;
  }

  .buy-whatsapp-btn:active {
    transform: scale(0.97);
  }
</style>

<script>
  document.querySelectorAll('.buy-whatsapp-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var number = btn.dataset.waNumber;
      if (!number) return;

      var message = window.location.href;

      var productTitle = document.querySelector('[class*="product-title"] h1, h1[class*="product"], .product__title h1');
      if (productTitle) {
        message += '\n\nProduct: ' + productTitle.textContent.trim();
      }

      var variantEl = document.querySelector('[data-rbrselector="selectBoxWrapper"] ._placeholder_kbu9k_98, [data-rbrselector="selectBoxWrapper"] ._selectedValue_kbu9k_98, select[name="id"]');
      if (variantEl) {
        var vt = variantEl.tagName === 'SELECT' ? variantEl.options[variantEl.selectedIndex].text : variantEl.textContent.trim();
        if (vt && !vt.includes('Select')) message += '\nVariant: ' + vt;
      }

      var qtyInput = document.querySelector('input[name="quantity"]');
      if (qtyInput && qtyInput.value != '1') message += '\nQty: ' + qtyInput.value;

      var bundleDetails = [];
      document.querySelectorAll('[data-rbrselector="discountOptionV5"] input:checked').forEach(function(radio) {
        var text = radio.closest('[data-rbrselector="discountOptionV5"]');
        if (text) bundleDetails.push(text.textContent.trim().replace(/\s+/g, ' '));
      });
      if (bundleDetails.length) message += '\nBundle: ' + bundleDetails.join(' | ');

      message += '\n\n\n';
      window.open('https://wa.me/' + number + '?text=' + encodeURIComponent(message), '_blank');
    });
  });
</script>

{% schema %}
{
  "name": "Buy via WhatsApp",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Order via WhatsApp"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Order on WhatsApp"
    },
    {
      "type": "paragraph",
      "content": "Phone number is taken from Theme Settings > Mobile Nav / WhatsApp / Announcement > WhatsApp number. Configure it there."
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Buy via WhatsApp",
      "category": "Custom"
    }
  ]
}
{% endschema %}

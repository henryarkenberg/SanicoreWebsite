{% doc %}
  @prompt
    An urgency timer
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-urgency-timer-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: center;
  }

  .ai-urgency-timer-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.spacing }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
  }

  .ai-urgency-timer-countdown-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: {{ block.settings.spacing }}px;
    flex-wrap: wrap;
  }

  .ai-urgency-timer-unit-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: {{ block.settings.unit_width }}px;
  }

  .ai-urgency-timer-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    font-weight: 700;
    color: {{ block.settings.number_color }};
    line-height: 1;
    margin-bottom: 8px;
  }

  .ai-urgency-timer-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.text_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-urgency-timer-message-{{ ai_gen_id }} {
    margin-top: {{ block.settings.spacing }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.message_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-urgency-timer-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-urgency-timer-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-urgency-timer-value-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.number_size }}px * 0.8);
    }

    .ai-urgency-timer-unit-{{ ai_gen_id }} {
      min-width: calc({{ block.settings.unit_width }}px * 0.8);
    }
  }
{% endstyle %}

<urgency-timer-{{ ai_gen_id }}
  class="ai-urgency-timer-{{ ai_gen_id }}"
  data-end-date="{{ block.settings.end_date }}"
  data-end-time="{{ block.settings.end_time }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <h3 class="ai-urgency-timer-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
  {% endif %}

  <div class="ai-urgency-timer-countdown-{{ ai_gen_id }}">
    {% if block.settings.show_days %}
      <div class="ai-urgency-timer-unit-{{ ai_gen_id }}">
        <div class="ai-urgency-timer-value-{{ ai_gen_id }}" data-unit="days">00</div>
        <div class="ai-urgency-timer-label-{{ ai_gen_id }}">{{ block.settings.label_days }}</div>
      </div>
    {% endif %}

    {% if block.settings.show_hours %}
      <div class="ai-urgency-timer-unit-{{ ai_gen_id }}">
        <div class="ai-urgency-timer-value-{{ ai_gen_id }}" data-unit="hours">00</div>
        <div class="ai-urgency-timer-label-{{ ai_gen_id }}">{{ block.settings.label_hours }}</div>
      </div>
    {% endif %}

    {% if block.settings.show_minutes %}
      <div class="ai-urgency-timer-unit-{{ ai_gen_id }}">
        <div class="ai-urgency-timer-value-{{ ai_gen_id }}" data-unit="minutes">00</div>
        <div class="ai-urgency-timer-label-{{ ai_gen_id }}">{{ block.settings.label_minutes }}</div>
      </div>
    {% endif %}

    {% if block.settings.show_seconds %}
      <div class="ai-urgency-timer-unit-{{ ai_gen_id }}">
        <div class="ai-urgency-timer-value-{{ ai_gen_id }}" data-unit="seconds">00</div>
        <div class="ai-urgency-timer-label-{{ ai_gen_id }}">{{ block.settings.label_seconds }}</div>
      </div>
    {% endif %}
  </div>

  {% if block.settings.expired_message != blank %}
    <div class="ai-urgency-timer-message-{{ ai_gen_id }}" style="display: none;" data-expired-message>
      {{ block.settings.expired_message }}
    </div>
  {% endif %}
</urgency-timer-{{ ai_gen_id }}>

<script>
  (function() {
    class UrgencyTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endDate = this.dataset.endDate;
        this.endTime = this.dataset.endTime;
        this.interval = null;
      }

      connectedCallback() {
        if (!this.endDate || !this.endTime) {
          return;
        }

        this.daysElement = this.querySelector('[data-unit="days"]');
        this.hoursElement = this.querySelector('[data-unit="hours"]');
        this.minutesElement = this.querySelector('[data-unit="minutes"]');
        this.secondsElement = this.querySelector('[data-unit="seconds"]');
        this.expiredMessageElement = this.querySelector('[data-expired-message]');
        this.countdownElement = this.querySelector('.ai-urgency-timer-countdown-{{ ai_gen_id }}');

        this.startTimer();
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      startTimer() {
        const endDateTime = new Date(this.endDate + 'T' + this.endTime).getTime();

        this.updateTimer(endDateTime);

        this.interval = setInterval(() => {
          this.updateTimer(endDateTime);
        }, 1000);
      }

      updateTimer(endDateTime) {
        const now = new Date().getTime();
        const distance = endDateTime - now;

        if (distance < 0) {
          if (this.interval) {
            clearInterval(this.interval);
          }
          this.showExpiredMessage();
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        if (this.daysElement) {
          this.daysElement.textContent = String(days).padStart(2, '0');
        }
        if (this.hoursElement) {
          this.hoursElement.textContent = String(hours).padStart(2, '0');
        }
        if (this.minutesElement) {
          this.minutesElement.textContent = String(minutes).padStart(2, '0');
        }
        if (this.secondsElement) {
          this.secondsElement.textContent = String(seconds).padStart(2, '0');
        }
      }

      showExpiredMessage() {
        if (this.countdownElement) {
          this.countdownElement.style.display = 'none';
        }
        if (this.expiredMessageElement) {
          this.expiredMessageElement.style.display = 'block';
        }
      }
    }

    customElements.define('urgency-timer-{{ ai_gen_id }}', UrgencyTimer{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Urgency timer",
  "settings": [
    {
      "type": "header",
      "content": "Timer settings"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "End date",
      "info": "Format: YYYY-MM-DD (e.g., 2026-12-31)",
      "default": "2026-12-31"
    },
    {
      "type": "text",
      "id": "end_time",
      "label": "End time",
      "info": "Format: HH:MM:SS in 24-hour format (e.g., 23:59:59)",
      "default": "23:59:59"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Limited time offer"
    },
    {
      "type": "text",
      "id": "expired_message",
      "label": "Expired message",
      "default": "This offer has ended"
    },
    {
      "type": "header",
      "content": "Display units"
    },
    {
      "type": "checkbox",
      "id": "show_days",
      "label": "Show days",
      "default": true
    },
    {
      "type": "text",
      "id": "label_days",
      "label": "Days label",
      "default": "Days"
    },
    {
      "type": "checkbox",
      "id": "show_hours",
      "label": "Show hours",
      "default": true
    },
    {
      "type": "text",
      "id": "label_hours",
      "label": "Hours label",
      "default": "Hours"
    },
    {
      "type": "checkbox",
      "id": "show_minutes",
      "label": "Show minutes",
      "default": true
    },
    {
      "type": "text",
      "id": "label_minutes",
      "label": "Minutes label",
      "default": "Minutes"
    },
    {
      "type": "checkbox",
      "id": "show_seconds",
      "label": "Show seconds",
      "default": true
    },
    {
      "type": "text",
      "id": "label_seconds",
      "label": "Seconds label",
      "default": "Seconds"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Number color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Spacing",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 14,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "number_size",
      "label": "Number size",
      "min": 24,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "message_size",
      "label": "Message size",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "unit_width",
      "label": "Unit width",
      "min": 60,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Urgency timer"
    }
  ]
}
{% endschema %}

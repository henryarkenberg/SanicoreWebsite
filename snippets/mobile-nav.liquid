{%- liquid
  assign active_item = ''
  if template == 'index'
    assign active_item = 'home'
  elsif template contains 'collection'
    assign active_item = 'categories'
  elsif template contains 'product'
    assign active_item = 'best-selling'
  elsif template == 'cart'
    assign active_item = 'cart'
  endif

  if settings.mobile_nav_best_selling_product != blank
    assign best_selling_url = settings.mobile_nav_best_selling_product.url
  else
    assign best_selling_url = '/collections/all?sort_by=best-selling'
  endif
-%}

<mobile-nav>
  <nav class="mobile-nav__bar">
    <a href="{{ best_selling_url }}" class="mobile-nav__item{% if active_item == 'best-selling' %} mobile-nav__item--active{% endif %}">
      <svg class="mobile-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      <span class="mobile-nav__label">Best Selling</span>
    </a>

    <a href="/collections" class="mobile-nav__item{% if active_item == 'categories' %} mobile-nav__item--active{% endif %}">
      <svg class="mobile-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      <span class="mobile-nav__label">Categories</span>
    </a>

    <a href="/" class="mobile-nav__item mobile-nav__item--home{% if active_item == 'home' %} mobile-nav__item--active{% endif %}">
      <svg class="mobile-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
    </a>

    <a href="/pages/rewards" class="mobile-nav__item">
      <svg class="mobile-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12V8H6a2 2 0 01-2-2c0-1.1.9-2 2-2h12v4"/><path d="M4 6v12c0 1.1.9 2 2 2h14v-4"/><path d="M18 12a2 2 0 000-4H8v10h8a2 2 0 000-4H6"/></svg>
      <span class="mobile-nav__label">Rewards</span>
    </a>

    <a href="{{ routes.cart_url }}" class="mobile-nav__item mobile-nav__item--cart{% if active_item == 'cart' %} mobile-nav__item--active{% endif %}">
      <svg class="mobile-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
      <span class="mobile-nav__label">Cart</span>
      {% if cart.item_count > 0 %}
        <span class="mobile-nav__badge">{{ cart.item_count }}</span>
      {% endif %}
    </a>
  </nav>
</mobile-nav>

<style>
  mobile-nav {
    display: none;
    position: fixed;
    bottom: 16px;
    left: 16px;
    right: 16px;
    z-index: 100;
  }

  @media screen and (max-width: 749px) {
    mobile-nav {
      display: block;
    }

    .page-wrapper {
      padding-bottom: 80px;
    }

    .sticky-add-to-cart__bar[data-stuck='true'] {
      bottom: 80px !important;
    }
  }

  .mobile-nav__bar {
    display: flex;
    justify-content: space-around;
    align-items: center;
    background: var(--color-background);
    border-radius: 20px;
    box-shadow: 0 4px 24px rgb(0 0 0 / 0.1);
    padding: 4px 0;
    max-width: 480px;
    margin: 0 auto;
    position: relative;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  @supports (backdrop-filter: blur(16px)) or (-webkit-backdrop-filter: blur(16px)) {
    .mobile-nav__bar {
      background: rgb(var(--color-foreground-rgb) / 0.04);
    }
  }

  .mobile-nav__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    text-decoration: none;
    color: rgb(var(--color-foreground-rgb) / 0.4);
    font-size: 9px;
    line-height: 1.2;
    padding: 6px 8px 8px;
    min-width: 44px;
    min-height: 40px;
    justify-content: center;
    position: relative;
    -webkit-tap-highlight-color: transparent;
    transition: opacity 0.15s;
  }

  .mobile-nav__item:active {
    opacity: 0.6;
  }

  .mobile-nav__item--active {
    color: var(--color-foreground);
  }

  .mobile-nav__item--active .mobile-nav__icon {
    stroke-width: 2.5;
  }

  .mobile-nav__icon {
    width: 22px;
    height: 22px;
    display: block;
  }

  .mobile-nav__label {
    display: block;
  }

  .mobile-nav__item--home {
    background: var(--color-primary-button-background);
    color: var(--color-primary-button-text) !important;
    border-radius: 50%;
    width: 52px;
    height: 52px;
    min-width: 52px;
    padding: 0;
    margin-top: -18px;
    margin-bottom: 6px;
    box-shadow: 0 4px 12px rgb(0 0 0 / 0.2);
    transition: transform 0.15s ease;
  }

  .mobile-nav__item--home:active {
    transform: scale(0.92);
  }

  .mobile-nav__item--home .mobile-nav__icon {
    width: 26px;
    height: 26px;
  }

  .mobile-nav__item--home .mobile-nav__label {
    display: none;
  }

  .mobile-nav__badge {
    position: absolute;
    top: 0;
    right: 0;
    min-width: 18px;
    height: 18px;
    border-radius: 9px;
    padding: 0 5px;
    background: #e53935;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    line-height: 18px;
    text-align: center;
    pointer-events: none;
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.2);
  }

  [data-rbrselector="discountOptionV5"].fb-selected {
    background-color: #e8f5e9 !important;
    border: 2px solid #16a34a !important;
    padding-bottom: 52px;
  }

  .pipe-toggle {
    display: flex;
    background: rgb(var(--color-foreground-rgb) / 0.08);
    border-radius: 20px;
    padding: 3px;
    gap: 3px;
    margin-top: 8px;
  }

  .pipe-toggle__btn {
    flex: 1;
    border: none;
    background: transparent;
    color: rgb(var(--color-foreground-rgb) / 0.5);
    font: inherit;
    font-size: 13px;
    font-weight: 500;
    padding: 6px 12px;
    border-radius: 17px;
    cursor: pointer;
    transition: all 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .pipe-toggle__btn.active {
    background: #16a34a;
    color: #fff;
    box-shadow: 0 1px 4px rgb(22 163 74 / 0.3);
  }

  .pipe-toggle__btn:active {
    opacity: 0.7;
  }

  .whatsapp-btn {
    position: fixed;
    bottom: 88px;
    right: 16px;
    z-index: 99;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #25D366;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgb(37 211 102 / 0.4);
    transition: bottom 0.35s ease, transform 0.2s, box-shadow 0.2s;
    -webkit-tap-highlight-color: transparent;
  }

  .whatsapp-btn:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 24px rgb(37 211 102 / 0.5);
  }

  .whatsapp-btn:active {
    transform: scale(0.92);
  }

  .whatsapp-btn svg {
    width: 26px;
    height: 26px;
  }

  .whatsapp-btn--sticky {
    bottom: 155px;
  }

  @media screen and (min-width: 750px) {
    .whatsapp-btn {
      bottom: 24px;
      right: 24px;
    }
    .whatsapp-btn--sticky {
      bottom: 24px;
    }
  }

  .futuristic-announcement {
    position: relative;
    background: linear-gradient(90deg, #050505, #0f0f1a, #141428, #0f0f1a, #050505);
    background-size: 300% 100%;
    animation: annBg 8s ease infinite;
    padding: 10px 16px;
    text-align: center;
    overflow: hidden;
    z-index: 100;
  }

  .futuristic-announcement::before {
    content: '';
    position: absolute;
    top: 0;
    left: -150%;
    width: 150%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgb(0 255 136 / 0.08), transparent);
    animation: annSweep 6s ease-in-out infinite;
  }

  .futuristic-announcement::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 1px, rgb(255 255 255 / 0.015) 1px, rgb(255 255 255 / 0.015) 2px);
    pointer-events: none;
  }

  @keyframes annBg {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  @keyframes annSweep {
    0%, 100% { left: -150%; }
    50% { left: 100%; }
  }

  .announcement-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .announcement-text {
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: uppercase;
    font-weight: 700;
    background: linear-gradient(90deg, #00ff88, #00ccff, #a855f7, #00ff88);
    background-size: 300% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: annTextShine 5s linear infinite;
  }

  @keyframes annTextShine {
    0% { background-position: 0% center; }
    100% { background-position: 300% center; }
  }

  [data-rbrselector="discountOptionV5"] {
    position: relative;
  }

  .fb-buy-now {
    position: absolute;
    bottom: 8px;
    right: 8px;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 10px;
    padding: 10px 22px;
    font-weight: 700;
    font-size: 15px;
    cursor: pointer;
    box-shadow: 0 2px 8px rgb(0 0 0 / 0.25);
    transition: background 0.15s, transform 0.15s;
    z-index: 2;
    -webkit-tap-highlight-color: transparent;
  }

  .fb-buy-now:hover {
    background: #000;
    transform: scale(1.03);
  }

  .fb-buy-now:active {
    transform: scale(0.96);
  }

  #header-component .header__row {
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  @supports (backdrop-filter: blur(16px)) or (-webkit-backdrop-filter: blur(16px)) {
    #header-component .header__row {
      background: rgb(var(--color-background-rgb) / 0.7);
    }
  }
</style>

{% assign wa_number = settings.whatsapp_number | default: '15551234567' | replace: '+', '' | replace: ' ', '' %}
<a href="#" class="whatsapp-btn" onclick="event.preventDefault(); openWhatsApp(this.dataset.waNumber);" data-wa-number="{{ wa_number }}" aria-label="Chat on WhatsApp">
  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
</a>

<script>
  function setupPipeToggle(container) {
    var wrapper = container.querySelector('[data-rbrselector="selectBoxWrapper"]');
    if (!wrapper || wrapper.classList.contains('pst-done')) return;
    wrapper.classList.add('pst-done');

    var display = wrapper.querySelector('._placeholder_kbu9k_98, ._selectedValue_kbu9k_98');
    var currentVal = display ? display.textContent.trim() : '1 Meter';

    var indexEl = container.querySelector('._indexLabel_kbu9k_13');
    var idx = indexEl ? indexEl.textContent.trim() : '';

    var toggle = document.createElement('div');
    toggle.className = 'pipe-toggle';
    toggle.innerHTML = '<button type="button" class="pipe-toggle__btn' + (currentVal === '1 Meter' ? ' active' : '') + '" data-value="1 Meter">' + (idx ? idx + ' ' : '') + '1 Meter</button><button type="button" class="pipe-toggle__btn' + (currentVal === '1.5 Meters' ? ' active' : '') + '" data-value="1.5 Meters">' + (idx ? idx + ' ' : '') + '1.5 Meters</button>';

    wrapper.parentNode.insertBefore(toggle, wrapper.nextSibling);
    wrapper.style.display = 'none';

    toggle.addEventListener('click', function(e) {
      var btn = e.target.closest('.pipe-toggle__btn');
      if (!btn || btn.classList.contains('active')) return;

      var targetValue = btn.dataset.value;
      var trigger = wrapper.querySelector('._container_kbu9k_42');
      if (!trigger) return;

      trigger.click();

      setTimeout(function() {
        var candidates = document.querySelectorAll('span, div, button, li');
        var clicked = false;
        candidates.forEach(function(el) {
          if (clicked) return;
          var text = el.textContent.trim();
          if ((text === '1 Meter' || text === '1.5 Meters') && text === targetValue && el.offsetParent !== null) {
            var rect = el.getBoundingClientRect();
            if (rect.width > 0 && rect.height > 0) {
              el.click();
              clicked = true;
            }
          }
        });

        if (clicked) {
          toggle.querySelectorAll('.pipe-toggle__btn').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
        }
      }, 300);
    });
  }

  function initPipeToggles() {
    document.querySelectorAll('[data-rbrselector="variantSelectorsOpenSelectorContainer"]').forEach(setupPipeToggle);
  }

  function fixVariantLabels() {
    document.querySelectorAll('[data-rbrselector="variantSelectorsOpenSelectorContainer"]').forEach(function(container) {
      container.querySelectorAll('span, div, label, p').forEach(function(el) {
        if (el.textContent.trim().toLowerCase() === 'variants' && !el.classList.contains('fb-fixed') && el.children.length === 0) {
          el.textContent = 'Pipe Size';
          el.classList.add('fb-fixed');
        }
      });
    });
  }

  function enhanceSelectedOption() {
    document.querySelectorAll('[data-rbrselector="discountOptionV5"]').forEach(function(option) {
      var isChecked = !!option.querySelector('input:checked');

      option.classList.toggle('fb-selected', isChecked);

      var buyBtn = option.querySelector('.fb-buy-now');
      if (isChecked && !buyBtn) {
        buyBtn = document.createElement('button');
        buyBtn.type = 'button';
        buyBtn.className = 'fb-buy-now';
        buyBtn.textContent = 'Buy Now \u2192';
        option.appendChild(buyBtn);

        buyBtn.addEventListener('click', function(ev) {
          ev.stopPropagation();
          var addBtn = document.querySelector('button[name="add"], .product-form__submit, [data-add-to-cart]');
          if (addBtn) {
            addBtn.click();
            setTimeout(function() { window.location.href = '/checkout'; }, 400);
          } else {
            var form = document.querySelector('form[action*="/cart/add"]');
            if (form) {
              var submitBtn = form.querySelector('button[type="submit"]');
              if (submitBtn) {
                submitBtn.click();
                setTimeout(function() { window.location.href = '/checkout'; }, 400);
              }
            }
          }
        });
      } else if (!isChecked && buyBtn) {
        buyBtn.remove();
      }
    });
  }

  function enhanceFastBundle() {
    initPipeToggles();
    fixVariantLabels();
    enhanceSelectedOption();
  }

  var fbObserver = new MutationObserver(function() {
    enhanceFastBundle();
  });

  fbObserver.observe(document.documentElement, { childList: true, subtree: true });

  function openWhatsApp(number) {
    if (!number) return;
    var message = 'Check out this product: ' + window.location.href;
    var variantEl = document.querySelector('[data-rbrselector="selectBoxWrapper"] ._placeholder_kbu9k_98, [data-rbrselector="selectBoxWrapper"] ._selectedValue_kbu9k_98, select[name="id"] option:checked');
    if (variantEl) {
      var vt = variantEl.textContent.trim();
      if (vt && vt !== '1 Meter' && vt !== '1.5 Meters') {
        vt = document.querySelector('._container_kbu9k_42 ._placeholder_kbu9k_98, ._container_kbu9k_42 ._selectedValue_kbu9k_98');
        if (vt) vt = vt.textContent.trim();
      }
      if (vt) message += '\nVariant: ' + vt;
    }
    var qtyEl = document.querySelector('input[name="quantity"]');
    if (qtyEl && qtyEl.value != '1') message += '\nQty: ' + qtyEl.value;
    message += '\n\n\n';
    window.open('https://wa.me/' + number + '?text=' + encodeURIComponent(message), '_blank');
  }

  function setupWhatsAppSticky() {
    var waBtn = document.querySelector('.whatsapp-btn');
    var stickyBar = document.querySelector('.sticky-add-to-cart__bar');
    if (!waBtn || !stickyBar) return;

    function updateWaPosition() {
      waBtn.classList.toggle('whatsapp-btn--sticky', stickyBar.getAttribute('data-stuck') === 'true');
    }

    updateWaPosition();
    var stickyObserver = new MutationObserver(updateWaPosition);
    stickyObserver.observe(stickyBar, { attributes: true, attributeFilter: ['data-stuck'] });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      setTimeout(enhanceFastBundle, 1500);
      setTimeout(setupWhatsAppSticky, 1600);
    });
  } else {
    setTimeout(enhanceFastBundle, 1500);
    setTimeout(setupWhatsAppSticky, 1600);
  }
</script>